/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage
/.auth
/test-results
/playwright-report
/blob-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

